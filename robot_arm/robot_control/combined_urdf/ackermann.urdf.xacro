<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro" name="ackermann_chassis">

  <!-- ====== Geometry (edit as needed) ====== -->
  <xacro:property name="wheelbase"          value="0.22"/>     <!-- centre axis of front left wheel to centre axis of rear left wheel in meters (same parameter for rigth side) -->
  <xacro:property name="front_track"        value="0.2225"/> <!-- centre of front wheel to centre of right front wheel in meters -->
  <xacro:property name="rear_track"         value="0.2225"/> <!-- centre of rear wheel to centre of right rear wheel in meters -->
  <xacro:property name="front_wheel_radius" value="0.05"/>  <!-- radius of a wheel -->
  <xacro:property name="rear_wheel_radius"  value="0.05"/>  <!-- radius of a wheel -->

<!-- chassis parameters for RViz or Gazebo -->
  <xacro:property name="chassis_height"     value="0.063"/>     <!-- total height of chassis from ground to top in m -->
  <xacro:property name="clearance"          value="0.022"/>     <!-- total clearance chassis has from ground to beginning of chassis -->
  <xacro:property name="z_base"             value="0.0535"/>    <!-- clearance + chassis_height/2 -->


  <!-- Switch: fake hardware vs real Arduino bridge -->
  <xacro:arg name="use_fake_hardware" default="true"/>
  <xacro:arg name="serial_port"  default="/dev/ttyACM0"/>
  <xacro:arg name="serial_baud"  default="115200"/>

  <!-- ====== Wheel macro (visual + collision) ====== -->
  <xacro:macro name="wheel_link" params="name r">
  <link name="${name}">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <!-- Rotate cylinder so its axis (Z) becomes Y: roll = +90° -->
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>  <!-- << correct -->
      <geometry><cylinder radius="${r}" length="0.05"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1.0"/></material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>  <!-- << same -->
      <geometry><cylinder radius="${r}" length="0.05"/></geometry>
    </collision>
  </link>
</xacro:macro>

  <!-- ====== Base (chassis) ====== -->
  <link name="base_link">
    <inertial>
      <origin xyz="0 0 ${z_base}"/>
      <mass value="8.0"/>
      <inertia ixx="0.1" iyy="0.1" izz="0.1" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>
      <origin xyz="0 0 ${z_base}"/>
      <geometry><box size="0.297 0.159 0.063"/></geometry>
      <material name="red"><color rgba="0.8 0.1 0.1 1.0"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 ${z_base}" rpy="0 0 0"/>
      <geometry><box size="0.297 0.159 0.063"/></geometry>
    </collision>
  </link>

  <!-- ====== Wheel links ====== -->
  <xacro:wheel_link name="front_left_wheel"  r="${front_wheel_radius}"/>
  <xacro:wheel_link name="front_right_wheel" r="${front_wheel_radius}"/>
  <xacro:wheel_link name="rear_left_wheel"   r="${rear_wheel_radius}"/>
  <xacro:wheel_link name="rear_right_wheel"  r="${rear_wheel_radius}"/>

  <!-- ====== Realsense Camera link ====== -->
  <!--link name="camera_link">
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
    <visual>  
      <geometry>
        <box size="0.1 0.02 0.02"/>
      </geometry>
    </visual>
  </link-->

  <!-- Optional optical frames (recommended) -->
  <!--link name ="camera_frame"/>
  <link name="camera_color_frame"/>
  <link name="camera_depth_frame"/>
  <link name="camera_color_optical_frame"/>
  <link name="camera_depth_optical_frame"/-->

  <!-- ====== Joints (x forward, y left, z up) ====== -->
  <!-- Both joints are still shown in RViz to accurately represent the chassis, however, one is a mimic to depict the tricycle setup -->
  <!-- Front steering (revolute about Z at wheel height) -->
  <joint name="front_left_steer_joint" type="revolute">
    <parent link="base_link"/>
    <child  link="front_left_wheel"/>
    <origin xyz="${wheelbase/2}  ${front_track/2}  ${front_wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <!-- safe ±48° from HTS-20H (300–700 units) -->
    <limit lower="-0.838" upper="0.838" effort="5" velocity="1.5"/>
  </joint>

  <joint name="front_right_steer_joint" type="revolute"> 
    <mimic joint="front_left_steer_joint" multiplier="1.0" offset="0.0"/> <!-- This is added so the chassis acts as a single steering actuator with a mirrored visual steering -->
    <parent link="base_link"/>
    <child  link="front_right_wheel"/>
    <origin xyz="${wheelbase/2} -${front_track/2}  ${front_wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.838" upper="0.838" effort="5" velocity="1.5"/>
  </joint>

  <!-- Rear drive (continuous spin about Y at wheel height) -->
  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="rear_left_wheel"/>
    <origin xyz="-${wheelbase/2}  ${rear_track/2}  ${rear_wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="50"/>
  </joint>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="rear_right_wheel"/>
    <origin xyz="-${wheelbase/2} -${rear_track/2}  ${rear_wheel_radius}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="50"/>
  </joint>

  <!-- ====== Realsense Camera Joint ====== -->
  <!--joint name="camera_mount_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.2 0 0.1" rpy="0 0 0"/>
  </joint-->  

  <!-- ====== Frame hierarchy ====== -->
  <!--joint name="camera_frame_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="color_frame_joint" type="fixed">
    <parent link="camera_frame"/>
    <child link="camera_color_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <joint name="depth_frame_joint" type="fixed">
    <parent link="camera_frame"/>
    <child link="camera_depth_frame"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint-->

  <!-- Optical frames (ROS standard orientation) -->
  <!--joint name="color_optical_joint" type="fixed">
    <parent link="camera_color_frame"/>
    <child link="camera_color_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint>

  <joint name="depth_optical_joint" type="fixed">
    <parent link="camera_depth_frame"/>
    <child link="camera_depth_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
  </joint-->

  <!-- ====== ros2_control unified system (fake vs real) ====== -->
  <ros2_control name="ackermann_serial" type="system">
    <hardware>
      <xacro:if value="$(arg use_fake_hardware)">
        <!-- Fake hardware for RViz/sim bring-up -->
        <plugin>fake_components/GenericSystem</plugin>
        <param name="mock_sensor_commands">true</param>
      </xacro:if>
      <xacro:unless value="$(arg use_fake_hardware)">
        <!-- Real hardware (Arduino bridge plugin) -->
        <plugin>ackermann_chassis/ArduinoSerialHardware</plugin>
        <param name="port">$(arg serial_port)</param>
        <param name="baud">$(arg serial_baud)</param>
        <param name="wheel_radius">${rear_wheel_radius}</param>
        <param name="max_mps">1.5</param>
        <param name="steer_limit_rad">0.837758</param>
      </xacro:unless>
    </hardware>

    <!-- Steering interfaces (position) -->
    <joint name="front_left_steer_joint">
      <command_interface name="position"/>
      <state_interface   name="position"/>
    </joint>
    <joint name="front_right_steer_joint"> <!-- No command interface to represent single steering actuator correctly -->
      <state_interface   name="position"/>
    </joint>

    <!-- Rear drive interfaces (velocity states only, to match plugin) -->
    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface   name="position"/>
      <state_interface   name="velocity"/>
    </joint>
  </ros2_control>

</robot>
