  <!-- ====== Joints (x forward, y left, z up) ====== -->
  <!-- Both joints are still shown in RViz to accurately represent the chassis, however, one is a mimic to depict the tricycle setup -->
  <!-- Front steering (revolute about Z at wheel height) -->
  <joint name="front_left_steer_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <origin rpy="0 0 0" xyz="0.11  0.11125  0.05"/>
    <axis xyz="0 0 1"/>
    <!-- safe ±48° from HTS-20H (300–700 units) -->
    <limit effort="5" lower="-0.838" upper="0.838" velocity="1.5"/>
  </joint>
  <joint name="front_right_steer_joint" type="fixed">
    <!--mimic joint="front_left_steer_joint" multiplier="1.0" offset="0.0"/-->
    <!-- This is added so the chassis acts as a single steering actuator with a mirrored visual steering -->
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <origin rpy="0 0 0" xyz="0.11 -0.11125  0.05"/>
    <axis xyz="0 0 1"/>
    <limit effort="5" lower="-0.838" upper="0.838" velocity="1.5"/>
  </joint>
  <!-- Rear drive (continuous spin about Y at wheel height) -->
  <joint name="rear_left_wheel_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <origin rpy="0 0 0" xyz="-0.11  0.11125  0.05"/>
    <axis xyz="0 1 0"/>
    <limit effort="10" velocity="50"/>
  </joint>
  <joint name="rear_right_wheel_joint" type="fixed">
